# DotaHelperAgent LLM 配置文件示例
# 使用方法：复制此文件为 llm_config.yaml 并根据需要修改配置

llm:
  # 是否启用 LLM
  enabled: true
  
  # API 基础 URL（本地部署）
  # 常见配置：
  # - LM Studio: http://127.0.0.1:1234/v1
  # - Ollama: http://127.0.0.1:11434/v1
  # - vLLM: http://127.0.0.1:8000/v1
  # - 阿里云百炼：https://dashscope.aliyuncs.com/compatible-mode/v1
  base_url: "http://127.0.0.1:1234/v1"
  
  # 模型名称
  # 根据实际部署的模型修改，例如：
  # - qwen3.5-9b
  # - llama-3-8b
  # - gemma-2-9b
  model: "qwen3.5-9b"
  
  # API Key（本地部署通常不需要，如果使用云服务请配置）
  api_key: null
  
  # 生成参数
  temperature: 0.7
  max_tokens: 2048
  top_p: 0.9
  
  # 超时时间（秒）
  timeout: 60
  
  # 是否启用流式输出
  stream: false
