# DotaHelperAgent 环境变量配置示例
# 复制此文件为 .env 并填入实际的 API Key

# DeepSeek API Key（推荐）
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 或者使用通用的 LLM API Key（备选）
# LLM_API_KEY=your_llm_api_key_here

# OpenDota API Key（可选，用于提高 API 请求限制）
# 从 https://www.opendota.com/ 获取
OPENDOTA_API_KEY=your_opendota_api_key_here

# Langfuse 配置（可选，用于追踪和监控）
# 从 https://langfuse.com/ 获取
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here

# 注意：
# 1. 不要将实际的 API Key 提交到代码仓库
# 2. .env 文件应该被添加到 .gitignore
# 3. 在生产环境中，使用安全的密钥管理服务